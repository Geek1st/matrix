{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./build/output",
    "rootDir": "./assets/scripts",
    "types": [
      "@cocos/creator-types/engine"
    ],
    "baseUrl": ".",
    "paths": {
      "db://assets/*": ["./assets/*"],
      "db://internal/*": ["./temp/*"]
    },
    "experimentalDecorators": true,
    "moduleResolution": "node"
  },
  "include": [
    "assets/scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "library",
    "temp",
    "native"
  ]
}
