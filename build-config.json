{
  "_comment": "Matrix Match-3 构建配置 — AI Agent 可直接编辑此文件，CLI 将读取它来构建",
  "_usage": "CocosCreator.exe --project <path> --build \"configPath=build-config.json\"",
  "_doc": "https://docs.cocos.com/creator/3.8/manual/zh/editor/publish/publish-in-command-line.html",

  "platform": "web-mobile",
  "debug": true,
  "md5Cache": false,
  "sourceMaps": true,
  "outputName": "matrix-match3",
  "name": "Matrix Match-3",
  "buildPath": "build",
  "startScene": "db://assets/scene/main.scene",

  "packages": {
    "web-mobile": {
      "orientation": "portrait",
      "polyfills": {
        "global": true,
        "asyncFunctions": true
      }
    },
    "wechatgame": {
      "appid": "wx0000000000000000",
      "orientation": "portrait",
      "separateEngine": false,
      "subpackage": false,
      "md5Cache": true,
      "remoteUrl": "",
      "startSceneAssetBundle": false,
      "workers": false
    }
  }
}
